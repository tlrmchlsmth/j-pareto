set dotenv-load
set dotenv-path := "../.env"

NAMESPACE := env("NAMESPACE", env("USER", "anon"))
KN := "kubectl -n " + NAMESPACE
#MODEL := "openai/gpt-oss-120b"
MODEL := "RedHatAI/Llama-3.3-70B-Instruct-FP8-dynamic"

default:
  just --list

# Deploy the disaggregated stack
deploy DECODE_TP="2" PREFILL_TP="1" CONFIG="default":
  DECODE_TP={{DECODE_TP}} PREFILL_TP={{PREFILL_TP}} CONFIG={{CONFIG}} python3 scripts/gen-nic-values.py
  DECODE_TP={{DECODE_TP}} PREFILL_TP={{PREFILL_TP}} CONFIG={{CONFIG}} MODEL="{{MODEL}}" helmfile apply -n {{NAMESPACE}}
  {{KN}} apply -f httproute.yaml

# Deploy with specific gateway provider
deploy-gw ENV:
  MODEL="{{MODEL}}" helmfile apply -e {{ENV}} -n {{NAMESPACE}}

# Show pod status
status:
  {{KN}} get pods -l llm-d.ai/guide=disagg

# Show all resources
status-all:
  {{KN}} get all -l llm-d.ai/guide=disagg

# Show helm releases
releases:
  helm list -n {{NAMESPACE}} | grep disagg

# Tear down the deployment
destroy:
  helmfile destroy -n {{NAMESPACE}}
  {{KN}} delete -f httproute.yaml --ignore-not-found=true

# Get gateway IP
gateway-ip:
  {{KN}} get gateway/infra-disagg-inference-gateway -o jsonpath='{.status.addresses[0].value}'

# Deploy the poker pod for interactive benchmarking
start-poker:
  {{KN}} apply -f ../poker/poker.yaml

# Open a shell in the poker pod with Justfile.remote
poke:
  #!/usr/bin/env bash
  set -euo pipefail
  mkdir -p ../.tmp
  export NAMESPACE="{{NAMESPACE}}"
  envsubst '${NAMESPACE}' < ../Justfile.remote > ../.tmp/Justfile.remote.tmp
  kubectl cp ../.tmp/Justfile.remote.tmp {{NAMESPACE}}/poker:/app/Justfile
  {{KN}} exec -it poker -- /bin/zsh

# Copy sweep results from poker pod to local ../results/
copy-results:
  #!/usr/bin/env bash
  set -euo pipefail
  mkdir -p ../results
  kubectl cp {{NAMESPACE}}/poker:/app/results/ ../results/
  echo "Results copied to ../results/"
  ls -la ../results/

# Generate a Google Sheet from collected results
collect-sheets TITLE:
  python3 ../collect-sweep-logs.py -d ../results --sheets "{{TITLE}}"
