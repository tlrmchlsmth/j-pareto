set dotenv-load
set dotenv-path := "../.env"

NAMESPACE := env("NAMESPACE", env("USER", "anon"))
KN := "kubectl -n " + NAMESPACE

# Benchmark configuration
MODEL := env("MODEL", "openai/gpt-oss-120b")
IMAGE := env("IMAGE", "ghcr.io/vcave/llm-d/llm-d-rocm:vllm_700_qk_triton_aiter_uni_attn_fix_23c8e6822")
GPU_MEM_UTIL := "0.95"
TARGET_DURATION := "60"
MIN_PROMPTS := "200"
HF_CACHE := "/mnt/nvme/models"
PRIORITY_CLASS := "low-priority"
EXTRA_VLLM_ARGS := env("EXTRA_VLLM_ARGS", "")
VLLM_ROCM_USE_AITER := env("VLLM_ROCM_USE_AITER", "1")
VLLM_ROCM_QUICK_REDUCE_QUANTIZATION := env("VLLM_ROCM_QUICK_REDUCE_QUANTIZATION", "INT4")
# Set value to override attention backend ('ROCM_AITER_UNIFIED_ATTN', 'TRITON_ATTN', etc...)
VLLM_ATTN_ARG := env("VLLM_ATTN_ARG", "")

_BASE_EXTRA := env("EXTRA_VLLM_ARGS", "")
EXTRA_VLLM_ARGS := if VLLM_ATTN_ARG != "" {
    _BASE_EXTRA + " --attention-backend " + VLLM_ATTN_ARG
} else {
    _BASE_EXTRA
}

# EP/DP sweep configuration
ENABLE_EP := "false"   # Enable --enable-expert-parallel (used by bench, always on for bench-ep/bench-dp)
MIN_GPU := "1"         # Min GPUs per job (skip configs below this)
MAX_GPU := "8"         # Max GPUs per job (limited by GPUs per node)

# Prefill workload
PREFILL_ISL := "4096"
PREFILL_OSL := "1"
PREFILL_CONCURRENCIES := "1 4 8 16"

# Decode workload
DECODE_ISL := "4096"
DECODE_OSL := "256"
DECODE_CONCURRENCIES := "4 8 12 16 20 24 28 32 40 48 56 64"

# Aggregated workload (actual ISL/OSL, no P/D specialization)
AGG_ISL := "4096"
AGG_OSL := "512"
AGG_CONCURRENCIES := "4 8 12 16 20 24 28 32 40 48 56 64"

default:
  just --list

# Render a single Job YAML to stdout (separated by ---)
_job-yaml JOB_NAME GPU_COUNT TP DP ENABLE_EP WORKLOAD_TYPE ISL OSL CONCURRENCY_LEVELS:
  #!/usr/bin/env bash
  # 1. Define the network generator function
  generate_multus_networks() {
    local count=$1
    local networks="["

    for i in $(seq 1 "$count"); do
      networks+=$(printf '{"name":"sriov-rdma-vf","namespace":"default","interface":"net%d"}' "$i")
      
      if [ "$i" -lt "$count" ]; then
        networks+=","
      fi
    done
    
    networks+="]"
    echo "$networks"
  }
  MULTUS_NETWORKS=$(generate_multus_networks {{GPU_COUNT}})
  echo "---"
  env \
    JOB_NAME={{JOB_NAME}} \
    GPU_COUNT={{GPU_COUNT}} \
    TP={{TP}} \
    DP={{DP}} \
    ENABLE_EP={{ENABLE_EP}} \
    MODEL="{{MODEL}}" \
    VLLM_IMAGE="{{IMAGE}}" \
    WORKLOAD_TYPE={{WORKLOAD_TYPE}} \
    ISL={{ISL}} \
    OSL={{OSL}} \
    CONCURRENCY_LEVELS="{{CONCURRENCY_LEVELS}}" \
    TARGET_DURATION={{TARGET_DURATION}} \
    MIN_PROMPTS={{MIN_PROMPTS}} \
    GPU_MEM_UTIL={{GPU_MEM_UTIL}} \
    HF_CACHE_HOST_PATH="{{HF_CACHE}}" \
    PRIORITY_CLASS="{{PRIORITY_CLASS}}" \
    MULTUS_NETWORKS="$MULTUS_NETWORKS" \
    EXTRA_VLLM_ARGS="{{EXTRA_VLLM_ARGS}}" \
    VLLM_ROCM_USE_AITER="{{VLLM_ROCM_USE_AITER}}" \
    VLLM_ROCM_QUICK_REDUCE_QUANTIZATION="{{VLLM_ROCM_QUICK_REDUCE_QUANTIZATION}}" \
    envsubst '${JOB_NAME} ${GPU_COUNT} ${TP} ${DP} ${ENABLE_EP} ${MODEL} ${VLLM_IMAGE} ${WORKLOAD_TYPE} ${ISL} ${OSL} ${CONCURRENCY_LEVELS} ${TARGET_DURATION} ${MIN_PROMPTS} ${GPU_MEM_UTIL} ${HF_CACHE_HOST_PATH} ${PRIORITY_CLASS} ${MULTUS_NETWORKS} ${EXTRA_VLLM_ARGS} ${VLLM_ROCM_USE_AITER} ${VLLM_ROCM_QUICK_REDUCE_QUANTIZATION}' \
      < job.yaml

# Launch a single benchmark Job
_job JOB_NAME GPU_COUNT TP DP ENABLE_EP WORKLOAD_TYPE ISL OSL CONCURRENCY_LEVELS:
  just _job-yaml {{JOB_NAME}} {{GPU_COUNT}} {{TP}} {{DP}} {{ENABLE_EP}} {{WORKLOAD_TYPE}} {{ISL}} {{OSL}} "{{CONCURRENCY_LEVELS}}" \
    | {{KN}} replace --force -f -

# Launch TP sweep Jobs (prefill + decode at TP=1,2,4,8, DP=1, EP configurable)
bench:
  just _bench-yaml | {{KN}} replace --force -f -

# Launch DP sweep Jobs (multiple vLLM instances, EP on, fixed TP)
bench-dp:
  #!/usr/bin/env bash
  set -euo pipefail
  YAML=""
  for DP in 1 2 4 8; do
    YAML+="$(just _job-yaml "pd-config-prefill-dp${DP}" $DP 1 $DP true prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}")"$'\n'
    YAML+="$(just _job-yaml "pd-config-decode-dp${DP}" $DP 1 $DP true decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}")"$'\n'
  done
  echo "$YAML" | {{KN}} replace --force -f -

# Launch aggregated benchmark Jobs (actual workload, no P/D specialization)
bench-agg:
  just _bench-agg-yaml | {{KN}} replace --force -f -

# Launch all TP×DP combos (EP on, all workloads, constrained by [MIN_GPU, MAX_GPU] per node)
bench-full:
  #!/usr/bin/env bash
  set -euo pipefail
  COUNT=0
  YAML=""
  for TP in 1 2 4 8; do
    for DP in 1 2 4 8; do
      GPU_COUNT=$((TP * DP))
      # Enable EP if using DP
      if [ $DP -ne 1 ]; then EP=true; else EP=false; fi
      if [ $GPU_COUNT -ge {{MIN_GPU}} ] && [ $GPU_COUNT -le {{MAX_GPU}} ]; then
        YAML+="$(just _job-yaml "pd-config-prefill-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}")"$'\n'
        YAML+="$(just _job-yaml "pd-config-decode-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}")"$'\n'
        YAML+="$(just _job-yaml "pd-config-agg-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}")"$'\n'
        COUNT=$((COUNT + 3))
      fi
    done
  done
  echo "$YAML" | {{KN}} replace --force -f -
  echo "Launched $COUNT jobs ($(( COUNT / 3 )) TP×DP configs × 3 workloads)"

bench-tp-full:
  #!/usr/bin/env bash
  set -euo pipefail
  COUNT=0
  YAML=""
  for TP in 1 2 4 8; do
    for DP in 1; do
      GPU_COUNT=$((TP * DP))
      # Enable EP if using DP
      if [ $DP -ne 1 ]; then EP=true; else EP=false; fi
      if [ $GPU_COUNT -ge {{MIN_GPU}} ] && [ $GPU_COUNT -le {{MAX_GPU}} ]; then
        YAML+="$(just _job-yaml "pd-config-prefill-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}")"$'\n'
        YAML+="$(just _job-yaml "pd-config-decode-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}")"$'\n'
        YAML+="$(just _job-yaml "pd-config-agg-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}")"$'\n'
        COUNT=$((COUNT + 3))
      fi
    done
  done
  echo "$YAML" | {{KN}} replace --force -f -
  echo "Launched $COUNT jobs ($(( COUNT / 3 )) TP×DP configs × 3 workloads)"

# Launch all benchmarks (P/D sweep + aggregated)
bench-all:
  { just _bench-yaml; just _bench-agg-yaml; } | {{KN}} replace --force -f -

# (internal) Emit YAML for bench recipe
_bench-yaml:
  #!/usr/bin/env bash
  just _job-yaml pd-config-prefill-tp1 1 1 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job-yaml pd-config-prefill-tp2 2 2 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job-yaml pd-config-prefill-tp4 4 4 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job-yaml pd-config-prefill-tp8 8 8 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job-yaml pd-config-decode-tp1 1 1 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job-yaml pd-config-decode-tp2 2 2 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job-yaml pd-config-decode-tp4 4 4 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job-yaml pd-config-decode-tp8 8 8 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"

# (internal) Emit YAML for bench-agg recipe
_bench-agg-yaml:
  #!/usr/bin/env bash
  just _job-yaml pd-config-agg-tp1 1 1 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job-yaml pd-config-agg-tp2 2 2 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job-yaml pd-config-agg-tp4 4 4 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job-yaml pd-config-agg-tp8 8 8 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"

# Wait for all benchmark Jobs to complete
wait:
  #!/usr/bin/env bash
  set -euo pipefail
  echo "Waiting for all pd-config benchmark jobs to complete..."
  for job in $({{KN}} get jobs -l app=pd-config-bench -o jsonpath='{.items[*].metadata.name}'); do
    echo "  Waiting for $job..."
    {{KN}} wait --for=condition=complete --timeout=3h "job/$job" || \
      echo "  WARNING: $job did not complete successfully"
  done
  echo "All jobs finished."

# Collect results from completed Jobs and generate CSVs
collect:
  python3 collect.py -n {{NAMESPACE}}

# Collect results and upload to Google Sheets with Pareto charts
collect-sheets TITLE="PD Config ":
  python3 collect.py -n {{NAMESPACE}} --sheets "{{TITLE}} {{MODEL}} {{IMAGE}} {{EXTRA_VLLM_ARGS}} VLLM_ROCM_USE_AITER={{VLLM_ROCM_USE_AITER}} VLLM_ROCM_QUICK_REDUCE_QUANTIZATION={{VLLM_ROCM_QUICK_REDUCE_QUANTIZATION}} VLLM_ATTN_ARG={{VLLM_ATTN_ARG}}"

# Show status of benchmark Jobs and Pods
status:
  {{KN}} get jobs -l app=pd-config-bench

# Clean up all benchmark Jobs
clean:
  {{KN}} delete jobs -l app=pd-config-bench --ignore-not-found=true 2>/dev/null
